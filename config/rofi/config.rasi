/* Rofi main config. The look lives in theme.rasi. */
configuration {
    modi:                       "drun,run,window";
    show-icons:                 true;
    icon-theme:                 "Papirus-Dark";
    drun-display-format:        "{name}";
    display-drun:               " Apps";
    display-run:                " Run";
    display-window:             " Windows";
    kb-cancel:                  "Escape";
}

@theme "~/.config/rofi/theme.rasi"
